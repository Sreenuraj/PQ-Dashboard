{
  "name": "pq-dashboard",
  "version": "1.0.0",
  "description": "PostQode AI Agent Observability Dashboard",
  "main": "server/index.js",
  "type": "commonjs",
  "scripts": {
    "server": "nodemon server/index.js",
    "dev": "vite --config vite.config.js --port 5173 --open",
    "start": "node server/index.js",
    "parse": "node server/parser/index.js",
    "postinstall": "node -e \"const fs=require('fs'),https=require('https');fs.mkdirSync('src/img',{recursive:true});const f=fs.createWriteStream('src/img/logo.svg');https.get('https://postqode.ai/favicon.svg',r=>r.pipe(f)).on('error',()=>{});\""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chart.js": "^4.5.1",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "vite": "^6.3.1"
  }
}
